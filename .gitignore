# Python
__pycache__/
*.py[cod]
.venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.import_linter_cache/
*.egg-info/

# Node
node_modules/
dist/

# Local environment
.env

# Terraform: providers, state, and variable values stay local
# (.terraform.lock.hcl is tracked).
.terraform/
*.tfstate
*.tfstate.*
*.tfvars

# Feed snapshots are large; only the trimmed test fixture is tracked.
*.pb
!backend/tests/fixtures/*.pb
